        "agents": ["product-analyst", "architect", "ui-ux-designer", "planner", "implementor", "backend-dev", "frontend-dev", "tester", "code-reviewer"],
        "phases": ["analysis", "dispatch", "collection", "review", "report"],
        "dispatch_order": "sequential_then_parallel"
